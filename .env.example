# Get this from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=replace_me

# Your personal chat id, or a group chat id.
# To find it: send a message to your bot, then open:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
TELEGRAM_CHAT_ID=replace_me

# Plaza listings URL sorted by publication date, newest first.
LIST_URL=https://plaza.newnewnew.space/aanbod/wonen#?gesorteerd-op=publicatiedatum-

# Recommended 60-120 seconds. Don't set this too low (local loop only).
CHECK_INTERVAL_SECONDS=60

# First run behavior:
# false = save all currently visible listings but do not send them; only future new publications are sent.
# true  = send all currently visible listings on first run.
SEND_EXISTING_ON_FIRST_RUN=false

# Optional filters. Leave empty to watch everything.
CITY_FILTER=Amsterdam
MAX_TOTAL_RENT=

# Browser settings.
HEADLESS=true
BROWSER_LOCALE=nl-NL
SLOW_MO_MS=0

# Local state database.
DB_PATH=plaza_seen.sqlite3

# Debug: dump each listing's extracted text to debug_plaza_<id>.txt
DEBUG_DUMP_TEXT=false
